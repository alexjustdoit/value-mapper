OPENAI_API_KEY=your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here

# LLM routing: true = free local Ollama, false = API providers
USE_LOCAL_LLM=false

# Ollama settings (only needed if USE_LOCAL_LLM=true)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi4

# Do not set locally — only set in Streamlit Community Cloud secrets
# SCC_MODE=true
