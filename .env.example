# LLM Provider
# Set USE_LOCAL_LLM=true to use Ollama locally (free, no API keys needed)
# Set USE_LOCAL_LLM=false to use OpenAI / Anthropic APIs
USE_LOCAL_LLM=false

# API Keys (required when USE_LOCAL_LLM=false)
# At least one of these must be set. Anthropic is preferred for calculator generation quality.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model overrides (optional — defaults shown)
OPENAI_MODEL=gpt-5.4-nano
CLAUDE_MODEL=claude-sonnet-4-6

# Ollama config (only used when USE_LOCAL_LLM=true)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi4

# Streamlit Community Cloud mode
# Set to true when deploying to SCC — enables per-session data isolation
SCC_MODE=false
